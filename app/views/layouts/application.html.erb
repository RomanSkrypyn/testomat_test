<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Testomat Test" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Testomat Test">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= asset_path('icons/main-icon.png') %>" type="image/png">
    <link rel="icon" href="<%= asset_path('icons/main-icon.svg') %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= asset_path('icons/main-icon.png') %>">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
