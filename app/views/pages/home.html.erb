<div class="min-h-screen bg-slate-50 py-12 px-4">
  <div class="max-w-2xl mx-auto">
    <% if user_signed_in? %>
      <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-4 mb-8 flex justify-between items-center">
        <div class="flex items-center space-x-3">
          <div class="h-8 w-8 bg-blue-600 rounded-lg flex items-center justify-center text-white font-black tracking-wider text-sm shadow-sm shadow-blue-500/30">
            <%= current_user.username[0].upcase %>
          </div>
          <div>
            <h1 class="text-base font-bold text-slate-900 leading-none">Testomat</h1>
            <span class="text-xs text-slate-500 font-medium">Logged in as <%= current_user.username %></span>
          </div>
        </div>

        <div class="flex items-center space-x-4">
          <div class="relative" data-controller="dropdown">
            <% unread_count = @notifications.select(&:unread?).size %>
            <button data-action="click->dropdown#toggle" class="relative p-2 text-slate-600 hover:text-slate-900 rounded-full hover:bg-slate-100 transition focus:outline-none" aria-label="Notifications">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
              </svg>
              <% if unread_count.positive? %>
                <span class="absolute top-1 right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[10px] font-bold text-white ring-2 ring-white">
                  <%= unread_count %>
                </span>
              <% end %>
            </button>

            <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-80 bg-white border border-slate-200 rounded-xl shadow-lg py-2 z-50 overflow-hidden">
              <div class="px-4 py-2 border-b border-slate-100 flex justify-between items-center">
                <h3 class="text-sm font-bold text-slate-900"><%= t('.notifications_heading') %></h3>
                <% if unread_count > 0 %>
                  <%= button_to t('.mark_all_read'), read_all_notifications_path, method: :post, class: "text-xs font-semibold text-blue-600 hover:text-blue-700 hover:underline bg-transparent border-0 cursor-pointer p-0" %>
                <% end %>
              </div>
              <div class="max-h-64 overflow-y-auto">
                <% if @notifications.present? %>
                  <% @notifications.each do |notification| %>
                    <div class="px-4 py-3 hover:bg-slate-50 transition border-b border-slate-50 last:border-0 flex items-start space-x-3 <%= 'bg-blue-50/40' if !notification.read %>">
                      <div class="flex-1 min-w-0">
                        <p class="text-xs text-slate-700 leading-snug">Mentioned by <b><%= notification.comment.user.username %></b></p>
                        <p class="text-xs text-slate-700 leading-snug"><i><%= notification.comment.body %></i></p>
                        <span class="text-[10px] text-slate-400 mt-1 block font-medium"><%= t('.ago', time: time_ago_in_words(notification.created_at)) %></span>
                      </div>
                      <% if notification.unread? %>
                        <%= button_to read_notification_path(notification), method: :post, class: "text-[10px] text-blue-500 hover:text-blue-700 bg-transparent border-0 cursor-pointer p-1 font-semibold", aria: { label: "Mark as read" } do %>
                          <span class="h-2 w-2 bg-blue-500 rounded-full block"></span>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                <% else %>
                  <div class="text-center py-8 text-slate-400 text-xs">
                    <%= t('.no_notifications') %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>

          <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "p-2 text-slate-500 hover:text-red-600 rounded-full hover:bg-red-50 transition", title: t('.sign_out') do %>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
            </svg>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="space-y-8">
      <div class="border-b pb-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-6"><%= t('.comments_title') %></h2>

        <!-- Search Bar Form -->
        <div class="mb-6">
          <%= form_with url: root_path, method: :get, local: true, class: "relative" do |f| %>
            <div class="relative rounded-lg shadow-sm">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.608 10.608Z" />
                </svg>
              </div>
              <%= f.text_field :query, value: params[:query], placeholder: t('.search_placeholder', default: 'Search comments...'), class: "block w-full rounded-lg border border-slate-200 bg-white py-2.5 pl-10 pr-10 text-sm text-slate-900 placeholder-slate-400 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500 transition duration-150" %>
              <% if params[:query].present? %>
                <%= link_to root_path, class: "absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-slate-600 transition" do %>
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if @comments.present? %>
          <div class="mb-8 space-y-4">
            <%= render @comments %>
          </div>

          <%= paginate @comments %>
        <% else %>
          <div class="text-center py-12">
            <p class="text-slate-600"><%= t('.no_comments') %></p>
          </div>
        <% end %>
      </div>

      <div>
        <h3 class="text-xl font-bold text-slate-900 mb-6"><%= t('.post_comment_title') %></h3>

        <div class="bg-slate-50 border border-slate-200 rounded-lg p-6">
          <% if user_signed_in? %>
            <%= render "comments/form", comment: @comment %>
          <% else %>
            <div class="text-center py-8">
              <p class="text-slate-600 mb-4"><%= t('.sign_in_to_comment') %></p>
              <%= link_to t('.sign_in'), new_user_session_path, class: "inline-block px-6 py-2 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold rounded-lg transition duration-200" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
