<div class="bg-slate-50 border border-slate-200 rounded-lg p-4 mb-4" data-controller="comments-form" data-comments-form-comment-id-value="<%= comment.id %>">
  <div data-comments-form-target="display">
    <div class="flex justify-between items-start mb-3">
      <div>
        <p class="text-sm font-semibold text-slate-900"><%= comment.user.email %></p>
        <p class="text-xs text-slate-500"><%= time_ago_in_words(comment.created_at) %> ago</p>
      </div>

      <% if user_signed_in? && current_user == comment.user %>
        <div class="flex gap-2">
          <button data-comments-form-target="editButton"
                  data-action="click->comments-form#openEdit"
                  class="text-xs text-blue-600 hover:text-blue-700 font-medium transition cursor-pointer">
            <%= t('.edit') %>
          </button>

          <%= link_to t('.delete'), comment_path(comment),
              data: { turbo_method: :delete, confirm: t('.confirm_delete'), "comments-form-target": "deleteButton" },
              class: "text-xs text-red-600 hover:text-red-700 font-medium transition" %>
        </div>
      <% end %>
    </div>

    <p class="text-slate-700 text-sm leading-relaxed"><%= highlight_mentions(simple_format(comment.body)) %></p>
  </div>

  <div data-comments-form-target="form" class="hidden mt-4">
    <div class="bg-white border border-slate-300 rounded-lg p-4">
      <%= form_with model: comment, local: true, data: { action: "submit->comments-form#handleSubmit" } do |f| %>
        <div class="mb-4">
          <%= f.text_area :body,
              rows: 4,
              data: { controller: 'mentions', mentions_target: 'textarea', action: 'input->mentions#handleInput' },
              class: "w-full px-4 py-3 bg-white border border-slate-300 rounded-lg text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none" %>
        </div>

        <div class="flex gap-3">
          <%= f.submit t('.submit'), class: "px-4 py-2 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold rounded-lg transition duration-200 shadow-lg hover:shadow-xl" %>

          <button type="button"
                  data-action="click->comments-form#closeEdit"
                  class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-900 font-semibold rounded-lg transition">
            <%= t('.cancel') %>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

